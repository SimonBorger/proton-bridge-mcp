{
  "mcpServers": {
    "proton_bridge": {
      "command": "<INSTALL_PATH>/proton_bridge_mcp/.venv/bin/python",
      "args": [
        "<INSTALL_PATH>/proton_bridge_mcp/proton_bridge_mcp.py"
      ],
      "env": {
        "PROTON_BRIDGE_USER": "your-bridge-username@example.com",
        "PROTON_BRIDGE_HOST": "127.0.0.1",
        "PROTON_BRIDGE_IMAP_PORT": "1143",
        "PROTON_BRIDGE_SMTP_PORT": "1025",
        "PROTON_BRIDGE_TLS_POLICY": "pinned",
        "PROTON_BRIDGE_CERT_PATH": "/Users/<YOU>/.config/proton-bridge-mcp/cert.pem",
        "PROTON_BRIDGE_DEFAULT_FROM": "your-bridge-username@example.com",
        "PROTON_BRIDGE_LOG_LEVEL": "INFO"
      }
    }
  }
}
